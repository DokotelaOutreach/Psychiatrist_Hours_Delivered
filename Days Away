SELECT 
    u.SURNAME + ', ' + u.FIRSTNAME AS DoctorName,
    d.RECORDID,
    d.USERID,
    d.STARTDATE,
    d.FINISHDATE,
    DATEDIFF(DAY, d.STARTDATE, d.FINISHDATE) + 1 AS DaysAway,
    d.AWAYREASON,
    d.RECORDSTATUS
FROM dbo.DAYSAWAY d
JOIN dbo.USERS u ON u.USERID = d.USERID
WHERE u.GROUPCODE IN (3, 4, 42)
  AND d.FINISHDATE >= '2026-01-01'
ORDER BY u.SURNAME, u.FIRSTNAME, d.STARTDATE
